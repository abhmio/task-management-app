PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-frontend-domain.com
CLIENT_URLS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
CLIENT_URL_PATTERNS=https://*.vercel.app
JWT_SECRET=replace_with_a_long_secure_random_secret
JWT_EXPIRES_IN=7d

DB_HOST=your-database-host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=taskflow
DB_CONNECTION_LIMIT=10

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
MAIL_FROM="TaskFlow <your_email@example.com>"
RESET_PASSWORD_URL=https://your-frontend-domain.com/reset-password
